MONGO_URI=mongodb://localhost:27017/
DB_NAME=book_search_system
JWT_SECRET=change-me
BOOKS_PATH=backend/books
INDEX_PATH=backend/data/search_index.pkl
SERVER_HOST=0.0.0.0
SERVER_PORT=5000
SERVER_DEBUG=true
TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe
PROCESS_CLEAR_EXISTING_DATA=false

# AI summarization (optional)
# GEMINI_API_KEY=...
# GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta
# GEMINI_MODEL=gemini-2.5-flash
#
# Prompt templates are REQUIRED when enabling AI summarization (no default prompt fallback).
# Templates support placeholders: {max_sentences} and {content}.
# You can write multi-line templates using \n in .env values.
# GEMINI_SUMMARY_PROMPT_TEMPLATE=Summarize in plain text using at most {max_sentences} sentences.\n\nCONTENT:\n{content}
